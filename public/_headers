/*
  Strict-Transport-Security: max-age=31536000
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(self), geolocation=(self), payment=(), usb=(), serial=(), bluetooth=()
  X-Frame-Options: DENY
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-4Q0npmxusTfLmW8fTQtuO923CD6kIg9XNQvcVgP8hJE='; style-src 'self'; img-src 'self' data: blob: https://tile.openstreetmap.org; connect-src 'self'; font-src 'self'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; object-src 'none'; manifest-src 'self'; worker-src 'self'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/napiyo-social-preview-v1.png
  Cache-Control: public, max-age=31536000, immutable
  Cross-Origin-Resource-Policy: cross-origin

/napiyo-icon.svg
  Cache-Control: public, max-age=86400
  Cross-Origin-Resource-Policy: cross-origin

/robots.txt
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600

/llms.txt
  Cache-Control: public, max-age=3600

/sw.js
  Cache-Control: no-cache

/manifest.webmanifest
  Cache-Control: public, max-age=3600
